# Copy this file to .env and fill in the values
# cp .env.example .env

# ── LangSmith (LangGraph observability) ────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=ai-course-architect

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_key_here

# ── Redis (Celery broker + result backend + LangGraph checkpointer) ──────────
# Phase 1 (local): redis://localhost:6379/0
# Phase 2 (AWS):   redis://your-elasticache-endpoint:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Database (Aurora RDS Serverless v2 — PostgreSQL) ─────────────────────────
# Local dev (SQLite, no setup needed):
#   DATABASE_URL=sqlite+aiosqlite:///./courses.db
#
# Production (Aurora RDS Serverless v2):
#   DATABASE_URL=postgresql+asyncpg://username:password@cluster-endpoint.region.rds.amazonaws.com:5432/courses
#
# The cluster endpoint is the Writer endpoint shown in the RDS console.
DATABASE_URL=

# ── S3 File Storage ──────────────────────────────────────────────────────────
# Bucket where tutor uploads are stored (create it in your AWS account first)
S3_UPLOADS_BUCKET=your-bucket-name-here
AWS_REGION=us-east-1
# On ECS Fargate the task execution role provides credentials automatically.
# For local dev, set these explicitly:
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ── S3 Vectors (RAG vector store) ────────────────────────────────────────────
# Create a vector bucket first (this is a DIFFERENT resource from a regular S3 bucket):
#   aws s3vectors create-vector-bucket --vector-bucket-name your-vector-bucket
# The index (S3_VECTORS_INDEX) is created automatically on first startup.
S3_VECTORS_BUCKET=your-vector-bucket-name
S3_VECTORS_INDEX=course-chunks

# ── Serper MCP (gap enrichment — Google Search via stdio, no Node.js required) ─
# Get your key at https://serper.dev (2,500 free searches/month on free tier)
SERPER_API_KEY=your_serper_key_here
