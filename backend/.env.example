# Copy this file to .env and fill in the values
# cp .env.example .env

# ── LangSmith (LangGraph observability) ────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=ai-course-architect

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# Phase 1 (local): sqlite+aiosqlite:///./courses.db  (default, no config needed)
# Phase 2 (Aurora): postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./courses.db
